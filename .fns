wiki() {
		local dir
		local cmd cmd2

		local file="."

		if [[ "$1" == "as" ]] || [[ "$1" == "work" ]]; then
			file="Work/"
			cmd="+Goyo"
		fi

		if [[ "$1" == "journal" ]] || [[ "$1" == "diary" ]] || [[ "$1" == "today" ]]; then
			dir="Diaries"
			file="$(date -I).md"
			cmd="+Goyo"
			cmd2="+Limelight"

		fi

		if [[ "$1" == "root" ]] || [[ "$1" == "index" ]] || [[ "$1" == "home" ]]; then
			file="index.md"
			cmd="+Goyo"
		fi

		if [[ "$1" == "brag" ]]; then
			file="Work/work-brag.md"
			cmd="+Goyo"
		fi

		cd ~/second-brain/"${dir}"
		nvim "${file}" $cmd $cmd2
}

brew-diff() {
    "$HOME/script/brew-audit" "$@"
}

ts-find() {
		local name=$1
		tailscale status | grep $name | awk '{ print $1 }'
}

vim-serve() {
		local port=$1
		nvim --headless --listen localhost:$port
		tailscale serve --bg --tcp $port localhost:$port
}

vim-connect() {
		local host=$1
		local port=$2
		nvim --remote-ui --server $(ts-find $host):$port
}
