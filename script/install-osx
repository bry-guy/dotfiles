#!/bin/bash
set -euo pipefail

usage() {
    echo "Usage: $0 profile <profile> | $0 <manifest> [manifest ...]" >&2
    exit 1
}

[ "$#" -ge 1 ] || usage

DOTFILES_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

if [ "$1" = "profile" ]; then
    [ "$#" -eq 2 ] || usage
    exec "$DOTFILES_DIR/script/brew-apply-profile" "$2"
fi

exec "$DOTFILES_DIR/script/brew-apply-manifest" "$@"
