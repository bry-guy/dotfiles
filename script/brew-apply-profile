#!/bin/bash
set -euo pipefail

usage() {
    echo "Usage: $0 [profile]" >&2
    exit 1
}

if [ "$#" -gt 1 ]; then
    usage
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/brew/lib.sh"

profile="$(resolve_profile "${1:-}")"
BREW_BIN="$(brew_bin)"
failures=0

while IFS= read -r manifest; do
    manifest_file="$(manifest_path "$manifest")"
    [ -f "$manifest_file" ] || error "Manifest '$manifest' not found at $manifest_file"

    if ! ensure_manifest_taps "$manifest"; then
        echo "Error: skipping manifest '$manifest' because one or more taps failed" >&2
        failures=$((failures + 1))
        continue
    fi

    echo "Applying brew manifest '$manifest' for profile '$profile'..."
    if ! DOTFILES_BREW_NO_DIRTY=1 "$BREW_BIN" bundle --verbose --file="$manifest_file"; then
        echo "Error: skipping manifest '$manifest' after bundle failure" >&2
        failures=$((failures + 1))
        continue
    fi
done < <(profile_manifests "$profile")

if [ "$failures" -gt 0 ]; then
    error "Skipped $failures manifest(s) while applying profile '$profile'. Review the errors above and rerun after fixing them."
fi
