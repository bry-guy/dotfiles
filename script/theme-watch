#!/bin/bash
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "theme-watch currently uses dark-notify and is macOS-only." >&2
  echo "On Linux, call ~/script/theme-sync from darkman or your desktop's appearance hooks." >&2
  exit 1
fi

sync_script="$HOME/script/theme-sync"
dark_notify_bin="$(command -v dark-notify || true)"

if [[ ! -x "$sync_script" ]]; then
  echo "Missing executable sync script: $sync_script" >&2
  exit 1
fi

if [[ -z "$dark_notify_bin" ]]; then
  echo "dark-notify is not installed or not on PATH." >&2
  exit 1
fi

"$sync_script" auto
exec "$dark_notify_bin" -c "$sync_script"
