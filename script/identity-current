#!/bin/bash
set -euo pipefail

profile_file="$HOME/.config/dotfiles/identity-profile"
personal_gitconfig_file="$HOME/.gitconfig.identity.local"
work_gitconfig_file="$HOME/.gitconfig.identity.work"
ssh_file="$HOME/.ssh/config.identity"

if [ -f "$profile_file" ]; then
    echo "profile: $(cat "$profile_file")"
else
    echo "profile: unset"
fi

echo "--- git identity (personal default) ---"
if [ -f "$personal_gitconfig_file" ]; then
    cat "$personal_gitconfig_file"
else
    echo "missing: $personal_gitconfig_file"
fi

echo "--- git identity (work override) ---"
if [ -f "$work_gitconfig_file" ]; then
    cat "$work_gitconfig_file"
else
    echo "missing: $work_gitconfig_file"
fi

echo "--- ssh identity ---"
if [ -f "$ssh_file" ]; then
    cat "$ssh_file"
else
    echo "missing: $ssh_file"
fi
