#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: $0 [profile]

Print the merged, normalized Brewfile for a profile.

Profile resolution order:
  1. explicit [profile]
  2. DOTFILES_BREW_PROFILE
  3. ~/.config/dotfiles/brew-profile
EOF
    exit 1
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ "$#" -gt 1 ]; then
    usage
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/brew/lib.sh"

profile="$(resolve_profile "${1:-}")"
manifest_files=()

while IFS= read -r manifest; do
    manifest_files+=("$(manifest_path "$manifest")")
done < <(profile_manifests "$profile")

if [ "${#manifest_files[@]}" -eq 0 ]; then
    error "Profile '$profile' does not reference any manifests."
fi

normalize_brewfile "${manifest_files[@]}"
