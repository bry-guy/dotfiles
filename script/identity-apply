#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: script/identity-apply <personal|work>

This writes machine-local identity files used by the tracked git and ssh config:
  ~/.gitconfig.identity.local   (personal default for github.com)
  ~/.gitconfig.identity.work    (work override for lumora.ghe.com remotes)
  ~/.ssh/config.identity        (host-based SSH identity selection)
  ~/.ssh/git-personal.pub
  ~/.ssh/git-work.pub

Environment overrides:
  DOTFILES_IDENTITY_PERSONAL_NAME
  DOTFILES_IDENTITY_PERSONAL_EMAIL
  DOTFILES_IDENTITY_PERSONAL_OP_ACCOUNT
  DOTFILES_IDENTITY_PERSONAL_KEY_VAULT
  DOTFILES_IDENTITY_PERSONAL_KEY_TITLE
  DOTFILES_IDENTITY_PERSONAL_LEGACY_KEY_TITLE

  DOTFILES_IDENTITY_WORK_NAME
  DOTFILES_IDENTITY_WORK_EMAIL
  DOTFILES_IDENTITY_WORK_OP_ACCOUNT
  DOTFILES_IDENTITY_WORK_KEY_VAULT
  DOTFILES_IDENTITY_WORK_KEY_TITLE
EOF
    exit 1
}

[ "$#" -eq 1 ] || usage
profile="$1"
case "$profile" in
    personal|work) ;;
    *) usage ;;
esac

mkdir -p "$HOME/.config/dotfiles" "$HOME/.ssh"

personal_name="${DOTFILES_IDENTITY_PERSONAL_NAME:-Bryan Smith}"
personal_email="${DOTFILES_IDENTITY_PERSONAL_EMAIL:-bryan@bry-guy.net}"
personal_op_account="${DOTFILES_IDENTITY_PERSONAL_OP_ACCOUNT:-my.1password.com}"
personal_key_vault="${DOTFILES_IDENTITY_PERSONAL_KEY_VAULT:-Private}"
personal_key_title="${DOTFILES_IDENTITY_PERSONAL_KEY_TITLE:-git-personal}"
personal_legacy_key_title="${DOTFILES_IDENTITY_PERSONAL_LEGACY_KEY_TITLE:-brainbook.local}"
personal_key_file="$HOME/.ssh/git-personal.pub"

work_name="${DOTFILES_IDENTITY_WORK_NAME:-Bryan Smith}"
work_email="${DOTFILES_IDENTITY_WORK_EMAIL:-bryan@lumoratech.com}"
work_op_account="${DOTFILES_IDENTITY_WORK_OP_ACCOUNT:-my.1password.com}"
work_key_vault="${DOTFILES_IDENTITY_WORK_KEY_VAULT:-Lumora}"
work_key_title="${DOTFILES_IDENTITY_WORK_KEY_TITLE:-git-work}"
work_key_file="$HOME/.ssh/git-work.pub"

op_read_public_key() {
    local account="$1"
    local vault="$2"
    local title="$3"

    if [ -n "$account" ]; then
        op --account "$account" read --no-newline "op://$vault/$title/public key" 2>/dev/null || true
    else
        op read --no-newline "op://$vault/$title/public key" 2>/dev/null || true
    fi
}

resolve_personal_key() {
    local key

    key="$(op_read_public_key "$personal_op_account" "$personal_key_vault" "$personal_key_title")"
    if [ -n "$key" ]; then
        printf '%s' "$key"
        return 0
    fi

    key="$(op_read_public_key "$personal_op_account" "$personal_key_vault" "$personal_legacy_key_title")"
    if [ -n "$key" ]; then
        printf '%s' "$key"
        return 0
    fi

    SSH_AUTH_SOCK="$HOME/.1password/agent.sock" ssh-add -L 2>/dev/null | awk 'NR==1 { print $1" "$2 }'
}

resolve_work_key() {
    op_read_public_key "$work_op_account" "$work_key_vault" "$work_key_title"
}

if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI (op) is required." >&2
    exit 1
fi

personal_public_key="$(resolve_personal_key)"
[ -n "$personal_public_key" ] || {
    echo "Unable to resolve personal public key from 1Password. Unlock 1Password and try again." >&2
    exit 1
}

work_public_key="$(resolve_work_key)"
if [ -z "$work_public_key" ] && [ "$profile" = "work" ]; then
    echo "Unable to resolve work public key from 1Password. Unlock 1Password and try again." >&2
    exit 1
fi

printf '%s\n' "$profile" > "$HOME/.config/dotfiles/identity-profile"
printf '%s\n' "$personal_public_key" > "$personal_key_file"
chmod 600 "$personal_key_file"

if [ -n "$work_public_key" ]; then
    printf '%s\n' "$work_public_key" > "$work_key_file"
    chmod 600 "$work_key_file"
fi

cat > "$HOME/.gitconfig.identity.local" <<EOF
[user]
	name = $personal_name
	email = $personal_email
EOF

cat > "$HOME/.gitconfig.identity.work" <<EOF
[user]
	name = $work_name
	email = $work_email
EOF

cat > "$HOME/.ssh/config.identity" <<EOF
Host github.com
	User git
	IdentitiesOnly yes
	IdentityFile ~/.ssh/git-personal.pub

Host lumora.ghe.com
	User git
	IdentitiesOnly yes
	IdentityFile ~/.ssh/git-work.pub

Host brainbook.local
	HostName github.com
	User git
	IdentitiesOnly yes
	IdentityFile ~/.ssh/git-personal.pub
EOF

chmod 600 "$HOME/.gitconfig.identity.local" "$HOME/.gitconfig.identity.work" "$HOME/.ssh/config.identity"

echo "Applied '$profile' identity files."
echo "- github.com -> personal ($personal_email)"
echo "- lumora.ghe.com -> work ($work_email)"
if [ -n "$work_public_key" ]; then
    echo "- wrote $work_key_file"
else
    echo "- warning: work public key unavailable; $work_key_file not updated"
fi
