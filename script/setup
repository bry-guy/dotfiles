#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: script/setup [brew-profile]

Examples:
  script/setup
  script/setup personal-macos
  script/setup work-macos
EOF
    exit 1
}

[ "$#" -le 1 ] || usage
BREW_PROFILE="${1:-}"

mkdir -p "$HOME/log"

# Log dotfiles setup
exec > >(tee -i "$HOME/log/dotfiles_install.log")
exec 2>&1

DOTFILES_DIR="$(git rev-parse --show-toplevel)"

# ===============================
# Detect OS and Arch
# ===============================

[ -f dot_detect_os ] && source dot_detect_os
[ -f dot_detect_arch ] && source dot_detect_arch
[ -f dot_detect_cloud ] && source dot_detect_cloud

if [ -n "$BREW_PROFILE" ]; then
    if [ ! -f "$DOTFILES_DIR/script/brew/profiles/$BREW_PROFILE" ]; then
        echo "Unknown brew profile: $BREW_PROFILE" >&2
        usage
    fi
fi

if [ -n "${OS_MAC:-}" ]; then
    echo "Detected macOS. Using macOS setup."
    source "$DOTFILES_DIR/script/setup-macos"
elif [ -n "${OS_LINUX:-}" ]; then
    if [ -f /etc/fedora-release ]; then
        echo "Detected Fedora: $(cat /etc/fedora-release)"
        source "$DOTFILES_DIR/script/setup-fedora"
    else
        echo "Detected Linux (non-Fedora). Using generic Linux setup with Linuxbrew."
        source "$DOTFILES_DIR/script/setup-linux"
    fi
else
    echo "Unsupported operating system."
    exit 1
fi

# ===============================
# Apply dotfiles
# ===============================

echo "Applying dotfiles."
chezmoi init --apply bry-guy

# ===============================
# Accept SSH Fingerprints
# ===============================

echo "Adding SSH fingerprints to known_hosts if not already present..."

ssh_hosts=(
    "github.com"
)

mkdir -p "$HOME/.ssh"

for host in "${ssh_hosts[@]}"; do
    if ! ssh-keygen -F "$host" >/dev/null; then
        echo "Adding $host to ~/.ssh/known_hosts..."
        ssh-keyscan -H "$host" >> "$HOME/.ssh/known_hosts"
        echo "Added $host to ~/.ssh/known_hosts."
    else
        echo "$host is already in ~/.ssh/known_hosts. Skipping."
    fi
done

if [ -n "$BREW_PROFILE" ]; then
        echo "Persisting brew profile '$BREW_PROFILE'..."
        mkdir -p "$HOME/.config/dotfiles"
        printf '%s\n' "$BREW_PROFILE" > "$HOME/.config/dotfiles/brew-profile"

        echo "Applying brew profile '$BREW_PROFILE'..."
        "$DOTFILES_DIR/script/brew-apply-profile" "$BREW_PROFILE"
elif [ -n "${CLOUD:-}" ]; then
        # ===============================
        # Install Cloud Deps
        # ===============================
        
        echo "Installing cloud development manifests..."
        "$DOTFILES_DIR/script/brew-apply-manifest" dev.common infra.common
fi

# ===============================
# Final Message
# ===============================

echo "Setup complete."
