#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: ~/script/setup [brew-profile]

Examples:
  ~/script/setup
  ~/script/setup personal-macos
  ~/script/setup work-macos
EOF
    exit 1
}

[ "$#" -le 1 ] || usage
BREW_PROFILE="${1:-}"

post_setup_checklist() {
    cat <<EOF

Post-setup checklist
====================

Automated setup is done. The following items are still worth checking manually:

1. Run a final package audit
   ~/script/brew-audit${BREW_PROFILE:+ $BREW_PROFILE}

2. Confirm 1Password setup
   - Sign in to 1Password
   - Enable the 1Password SSH agent
   - For personal machines: run '~/script/identity-apply personal' if needed
   - For work machines: defer '~/script/identity-apply work' until work identity details are finalized

3. Review macOS appearance and shell integration
   - Open a fresh terminal and confirm shell config loads as expected
   - Confirm Homebrew profile selection in ~/.config/dotfiles/brew-profile

4. Finish GUI-only macOS polish that is not fully automated
   - Dock app layout/order
   - Login Items in System Settings
   - Menu bar settings like battery percentage and clock seconds
   - Safari extension enablement/permissions

5. Review privacy/security prompts for installed apps
   - Accessibility permissions (e.g. Amethyst, Karabiner-Elements)
   - Screen Recording / Full Disk Access if needed
   - Any app-specific background item approvals

EOF
}

mkdir -p "$HOME/log"

# Log dotfiles setup
exec > >(tee -i "$HOME/log/dotfiles_install.log")
exec 2>&1

DOTFILES_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

# ===============================
# Detect OS and Arch
# ===============================

[ -f "$DOTFILES_DIR/.detect_os" ] && source "$DOTFILES_DIR/.detect_os"
[ -f "$DOTFILES_DIR/.detect_arch" ] && source "$DOTFILES_DIR/.detect_arch"
[ -f "$DOTFILES_DIR/.detect_cloud" ] && source "$DOTFILES_DIR/.detect_cloud"

if [ -n "$BREW_PROFILE" ]; then
    if [ ! -f "$DOTFILES_DIR/script/brew/profiles/$BREW_PROFILE" ]; then
        echo "Unknown brew profile: $BREW_PROFILE" >&2
        usage
    fi
fi

if [ -n "${OS_MAC:-}" ]; then
    echo "Detected macOS. Using macOS setup."
    source "$DOTFILES_DIR/script/setup-macos"
elif [ -n "${OS_LINUX:-}" ]; then
    if [ -f /etc/fedora-release ]; then
        echo "Detected Fedora: $(cat /etc/fedora-release)"
        source "$DOTFILES_DIR/script/setup-fedora"
    else
        echo "Detected Linux (non-Fedora). Using generic Linux setup with Linuxbrew."
        source "$DOTFILES_DIR/script/setup-linux"
    fi
else
    echo "Unsupported operating system."
    exit 1
fi

# ===============================
# Tracked files are already present via yadm
# ===============================

echo "Using tracked home-layout dotfiles from $DOTFILES_DIR."

# ===============================
# Accept SSH Fingerprints
# ===============================

echo "Adding SSH fingerprints to known_hosts if not already present..."

ssh_hosts=(
    "github.com"
)

mkdir -p "$HOME/.ssh"

for host in "${ssh_hosts[@]}"; do
    if ! ssh-keygen -F "$host" >/dev/null; then
        echo "Adding $host to ~/.ssh/known_hosts..."
        ssh-keyscan -H "$host" >> "$HOME/.ssh/known_hosts"
        echo "Added $host to ~/.ssh/known_hosts."
    else
        echo "$host is already in ~/.ssh/known_hosts. Skipping."
    fi
done

if [ -n "$BREW_PROFILE" ]; then
        echo "Persisting brew profile '$BREW_PROFILE'..."
        mkdir -p "$HOME/.config/dotfiles"
        printf '%s\n' "$BREW_PROFILE" > "$HOME/.config/dotfiles/brew-profile"

        echo "Applying brew profile '$BREW_PROFILE'..."
        "$DOTFILES_DIR/script/brew-apply-profile" "$BREW_PROFILE"

        if [ -n "${OS_MAC:-}" ] && command -v dark-notify >/dev/null 2>&1 && [ -f "$HOME/Library/LaunchAgents/net.bryguy.theme-sync.plist" ]; then
            echo "Enabling automatic theme sync launch agent..."
            "$DOTFILES_DIR/script/theme-sync-enable"
        fi
elif [ -n "${CLOUD:-}" ]; then
        # ===============================
        # Install Cloud Deps
        # ===============================
        
        echo "Installing cloud development manifests..."
        "$DOTFILES_DIR/script/brew-apply-manifest" dev.common infra.common
fi

# ===============================
# Final Message
# ===============================

post_setup_checklist

echo "Setup complete."
