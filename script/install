#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage:
  script/install profile <profile>
  script/install manifest <manifest> [manifest ...]
  script/install <fedora-env>
EOF
    exit 1
}

[ "$#" -ge 1 ] || usage

DOTFILES_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
[ -f "$DOTFILES_DIR/dot_detect_os" ] && source "$DOTFILES_DIR/dot_detect_os"

if [ -n "${OS_MAC:-}" ]; then
    case "$1" in
        profile)
            [ "$#" -eq 2 ] || usage
            exec "$DOTFILES_DIR/script/brew-apply-profile" "$2"
            ;;
        manifest)
            shift
            [ "$#" -ge 1 ] || usage
            exec "$DOTFILES_DIR/script/brew-apply-manifest" "$@"
            ;;
        *)
            exec "$DOTFILES_DIR/script/brew-apply-manifest" "$@"
            ;;
    esac
elif [ -n "${OS_LINUX:-}" ]; then
    if [ -f /etc/fedora-release ]; then
        [ "$#" -eq 1 ] || usage
        exec "$DOTFILES_DIR/script/install-fedora" "$1"
    fi

    case "$1" in
        profile)
            [ "$#" -eq 2 ] || usage
            exec "$DOTFILES_DIR/script/brew-apply-profile" "$2"
            ;;
        manifest)
            shift
            [ "$#" -ge 1 ] || usage
            exec "$DOTFILES_DIR/script/brew-apply-manifest" "$@"
            ;;
        *)
            exec "$DOTFILES_DIR/script/brew-apply-manifest" "$@"
            ;;
    esac
else
    echo "Unsupported operating system." >&2
    exit 1
fi
