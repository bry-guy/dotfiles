{
  "lastChangelogVersion": "0.66.1",
  "theme": "sunfly",
  "packages": [
    "git:github.com/nicobailon/pi-mcp-adapter",
    "git:github.com/nicobailon/pi-web-access",
    "git:github.com/lajarre/pi-vim",
    "git:github.com/bry-guy/pi-ez-worktree",
    "git:github.com/bry-guy/pi-ez-delegate"
